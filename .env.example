# NCBI Entrez — strongly recommended. With a key you get 10 req/s instead of 3.
# Get one at https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=
NCBI_EMAIL=you@example.com

# Optional: Upstash Redis for caching /api/expand and /api/pubmed responses
# AND for per-client (per-IP) rate limiting on the public API routes.
# Leave blank to disable both caching and rate limiting — local dev works
# fine without external deps.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Per-client rate limit (sliding window). Applied when Upstash is configured.
# Keyed on x-forwarded-for (first hop), so one noisy IP cannot exhaust the
# NCBI quota for others sharing the deployment.
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW=60 s
